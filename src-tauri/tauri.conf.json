{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "跨境电商定价系统",
  "version": "0.1.0",
  "identifier": "com.luciferase.pricing",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "跨境电商定价系统",
        "width": 1500,
        "height": 920,
        "minWidth": 1280,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
